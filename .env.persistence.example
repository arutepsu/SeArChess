# Local/demo persistence credentials only. Do not reuse these values for production.
# Postgres is the default Game Service runtime backend when PERSISTENCE_MODE is unset.
# Use PERSISTENCE_MODE=sqlite or PERSISTENCE_MODE=in-memory for lightweight local runs.

SEARCHESS_POSTGRES_URL=jdbc:postgresql://localhost:5432/searchess
SEARCHESS_POSTGRES_USER=searchess
SEARCHESS_POSTGRES_PASSWORD=searchess
SEARCHESS_MONGO_URI=mongodb://localhost:27017/searchess
